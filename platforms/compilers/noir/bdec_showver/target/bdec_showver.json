{"noir_version":"1.0.0-beta.19+74d6be658e1ad252f87943292ba09bdd4da80bd4","hash":"9224072007625364809","abi":{"parameters":[{"name":"verifier_pseudonym_public","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"public"},{"name":"disclosure_hash","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"public"},{"name":"revocation_root","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"public"},{"name":"policy_gpa_min","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"},{"name":"policy_allow_cs","type":{"kind":"boolean"},"visibility":"public"},{"name":"policy_allow_ee","type":{"kind":"boolean"},"visibility":"public"},{"name":"user_pk","type":{"kind":"struct","path":"loquat_lib::LoquatPublicKey","fields":[{"name":"elements","type":{"kind":"array","length":64,"type":{"kind":"field"}}}]},"visibility":"private"},{"name":"credential","type":{"kind":"struct","path":"Credential","fields":[{"name":"pseudonym_public","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}}},{"name":"pseudonym_signature","type":{"kind":"struct","path":"loquat_lib::LoquatSignature","fields":[{"name":"data","type":{"kind":"array","length":512,"type":{"kind":"integer","sign":"unsigned","width":8}}}]}},{"name":"attribute_hash","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}}},{"name":"credential_signature","type":{"kind":"struct","path":"loquat_lib::LoquatSignature","fields":[{"name":"data","type":{"kind":"array","length":512,"type":{"kind":"integer","sign":"unsigned","width":8}}}]}}]},"visibility":"private"},{"name":"verifier_pseudonym_sig","type":{"kind":"struct","path":"loquat_lib::LoquatSignature","fields":[{"name":"data","type":{"kind":"array","length":512,"type":{"kind":"integer","sign":"unsigned","width":8}}}]},"visibility":"private"},{"name":"shown_credential_sig","type":{"kind":"struct","path":"loquat_lib::LoquatSignature","fields":[{"name":"data","type":{"kind":"array","length":512,"type":{"kind":"integer","sign":"unsigned","width":8}}}]},"visibility":"private"},{"name":"revocation_path","type":{"kind":"array","length":20,"type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}}},"visibility":"private"},{"name":"gpa_tenths","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"degree_code","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"private"}],"return_type":null,"error_types":{}},"bytecode":"","debug_symbols":"","file_map":{"51":{"source":"use dep::loquat_lib::{LoquatPublicKey, LoquatSignature, loquat_verify, merkle_non_member};\n\nstruct Credential {\n    pseudonym_public: [u8; 32],\n    pseudonym_signature: LoquatSignature,\n    attribute_hash: [u8; 32],\n    credential_signature: LoquatSignature,\n}\n\nfn degree_allowed(degree_code: u8, allow_cs: bool, allow_ee: bool) -> bool {\n    (allow_cs & (degree_code == 1)) | (allow_ee & (degree_code == 2))\n}\n\nfn main(\n    verifier_pseudonym_public: pub [u8; 32],\n    disclosure_hash: pub [u8; 32],\n    revocation_root: pub [u8; 32],\n    policy_gpa_min: pub u32,\n    policy_allow_cs: pub bool,\n    policy_allow_ee: pub bool,\n    user_pk: LoquatPublicKey,\n    credential: Credential,\n    verifier_pseudonym_sig: LoquatSignature,\n    shown_credential_sig: LoquatSignature,\n    revocation_path: [[u8; 32]; 20],\n    gpa_tenths: u32,\n    degree_code: u8,\n) {\n    assert(loquat_verify(\n        credential.attribute_hash,\n        credential.credential_signature,\n        user_pk,\n    ));\n\n    assert(loquat_verify(\n        credential.pseudonym_public,\n        credential.pseudonym_signature,\n        user_pk,\n    ));\n\n    assert(loquat_verify(\n        verifier_pseudonym_public,\n        verifier_pseudonym_sig,\n        user_pk,\n    ));\n\n    assert(loquat_verify(\n        disclosure_hash,\n        shown_credential_sig,\n        user_pk,\n    ));\n\n    assert(merkle_non_member(user_pk, revocation_root, revocation_path));\n    assert(gpa_tenths >= policy_gpa_min);\n    assert(degree_allowed(degree_code, policy_allow_cs, policy_allow_ee));\n}\n","path":"/Users/takumiotsuka/Library/Mobile Documents/com~apple~CloudDocs/Desktop/Projects/research/thesis/noir/bdec_showver/src/main.nr"}}}